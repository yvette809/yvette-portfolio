# ── EmailJS configuration ──────────────────────────────────────
# Sign up at https://www.emailjs.com (free tier: 200 emails/month)
# 1. Email Services → connect Gmail/Outlook
# 2. Email Templates → create template using {{name}} {{email}} {{subject}} {{message}}
# 3. Account → API Keys → copy your public key
# 4. Copy this file to ".env.local" and fill in the values below
NEXT_PUBLIC_EMAILJS_SERVICE_ID=service_xxxxxxx
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=template_xxxxxxx
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=xxxxxxxxxxxxxxxx
